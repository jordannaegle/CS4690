{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    // Environment Settings
    "module": "es2020",
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "target": "es2020",
    "lib": [
      "es2020",
      "dom",
      "dom.iterable"
    ],
    // Other Outputs
    "sourceMap": true,
    // Stricter Typechecking Options
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    // Recommended Options
    "strict": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "skipLibCheck": true
  },
  "include": [
    "public/**/*.ts",
    "models/**/*.ts",
    "app.ts",
    "db.ts",
    "domain.ts",
    "seed.ts",
    "server.ts"
  ],
  "exclude": [
    "cypress",
    "cypress.config.ts",
    "node_modules"    // <-- ADDED: Best practice to prevent TS from scanning thousands of library files
  ]
}
